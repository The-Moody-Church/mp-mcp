# Ministry Platform base URL (no trailing slash, no /ministryplatformapi suffix)
MP_BASE_URL=https://your-church.ministryplatform.com

# OIDC client credentials (for user authentication)
# This is the OAuth2 client that handles the OIDC login flow (e.g., TM.Widgets)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Public URL where this MCP server is hosted (used for OIDC redirect URI)
PUBLIC_URL=https://your-mcp-domain.example.com

# Server
PORT=3000

# Access control (optional)
# Comma-separated MP User Group IDs. Only users in these groups can log in.
# Leave empty to allow any authenticated MP user.
ALLOWED_USER_GROUP_IDS=

# Additional allowed OAuth redirect URIs for dynamic client registration
# (comma-separated). https://claude.ai/api/mcp/auth_callback is always allowed.
# All entries must use https://.
ALLOWED_REDIRECT_URIS=
